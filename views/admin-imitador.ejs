<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="icon" href="/images/icono.png" type="image/png">
    <meta name="google-adsense-account" content="ca-pub-8003242291729928">
    <script async src="https.pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8003242291729928"
     crossorigin="anonymous"></script>
</head>
<body class="bg-dark text-light">
    <%- include('partials/header') %>
    <div class="admin-wrapper">
        <div class="container mt-5 mb-5">
        <h1 class="text-center mb-4"><%= title %></h1>
        <div class="card p-4 shadow">
            <form id="create-imitador-form">
                <div class="mb-3">
                    <label for="roomName" class="form-label">Nombre de la Sala</label>
                    <input type="text" class="form-control" id="roomName" placeholder="Ej: Sala de Imitadores" required>
                </div>
                <div class="mb-3">
                    <label for="roomPassword" class="form-label">Contraseña (Opcional)</label>
                    <input type="password" class="form-control" id="roomPassword" placeholder="Dejar en blanco para pública">
                </div>
                <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">Crear Sala de Imitador</button>
            </form>
        </div>

        <div class="mt-5">
            <%- include('partials/game_rules', { gameType: 'imitador' }) %>
        </div>
    </div>
</div>

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const gameType = '<%= gameType %>';
        let userUuid = localStorage.getItem('userUuid');

        if (!userUuid) {
            userUuid = 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
                const r = Math.random() * 16 | 0, v = c == 'x' ? r : (r & 0x3 | 0x8);
                return v.toString(16);
            });
            localStorage.setItem('userUuid', userUuid);
        }

        document.getElementById('create-imitador-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const name = document.getElementById('roomName').value;
            const password = document.getElementById('roomPassword').value;

            try {
                const response = await fetch(`/api/rooms/${gameType}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, password, creatorId: userUuid, settings: {} })
                });

                if (response.ok) {
                    const data = await response.json();
                    window.location.href = `/game/${gameType}/${data.roomId}`;
                } else {
                    alert('Error al crear la sala');
                }
            } catch (error) {
                console.error(error);
                alert('Error de conexión');
            }
        });
    </script>
</body>
</html>
