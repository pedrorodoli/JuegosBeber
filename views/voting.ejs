<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/voting.css">
    <!-- Favicon -->
    <link rel="icon" href="/images/icono.png" type="image/png">
    <meta name="google-adsense-account" content="ca-pub-8003242291729928">
    <script async src="https.pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8003242291729928"
     crossorigin="anonymous"></script>
    <style>
        body {
            font-family: 'Roboto', sans-serif;
            background: linear-gradient(135deg, #1a1a2e, #162447);
            animation: gradientBG 20s ease infinite;
            color: #f5f5f5;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
        }

        header { width: 100%; }

        .main-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
            width: 100%;
        }

        /* Contenedor de opciones de voto */
        #game-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 1rem;
            justify-items: center;
            align-items: center;
            margin-top: 2rem;
        }

        /* Opciones de votación con estilo moderno */
        .vote-option {
            background: rgba(255, 255, 255, 0.05);
            padding: 1rem 2rem;
            border-radius: 50px;
            font-weight: bold;
            text-align: center;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            border: 1px solid rgba(255, 75, 43, 0.2);
            color: #f5f5f5;
        }

        .vote-option:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 20px rgba(255, 75, 43, 0.5);
            border: 1px solid rgba(255, 75, 43, 0.5);
        }

        /* Overlay para resultados */
        #result-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(26, 26, 46, 0.9);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .result-content {
            background: rgba(255, 255, 255, 0.05);
            padding: 2rem 3rem;
            border-radius: 20px;
            text-align: center;
            color: #f5f5f5;
            backdrop-filter: blur(10px);
        }

        /* Nombre del ganador con glow sutil */
        .winner-name {
            font-size: 2rem;
            margin-top: 1rem;
            background: linear-gradient(90deg, #ff6b81, #ff4b2b);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 2px #ff6b81, 0 0 4px #ff4b2b, 0 0 6px #ff6b81;
        }

        /* Texto informativo legible */
        #game-container p {
            color: #f5f5f5;
            font-family: 'Roboto', sans-serif;
        }
    </style>
</head>
<body class="bg-dark text-light">
    <%- include('partials/header') %>
    <div class="main-container">
        <section id="game-voting" class="section">
            <div id="game-countdown" class="countdown-progress-container">
                <div class="countdown-progress-bar"></div>
                <span class="countdown-text"></span>
            </div>
            <h2 id="game-page-title">Votación</h2>
            <div id="game-container">
                <!-- Las opciones de voto se generarán dinámicamente -->
                <p>Cargando opciones de la votación...</p>
            </div>
        </section>
    </div>

    <!-- Overlay para el resultado final -->
    <div id="result-overlay">
        <div class="result-content">
            <h2>La votación ha terminado</h2>
            <p>El ganador es...</p>
            <div id="winner-name" class="winner-name"></div>
        </div>
    </div>

    <%- include('partials/game_rules', { gameType: 'voting' }) %>

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const GAME_TYPE = "<%= gameType %>";
        const ROOM_ID = "<%= roomId %>";
    </script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/voting.js"></script>
</body>
</html>
