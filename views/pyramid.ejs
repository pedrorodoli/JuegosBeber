<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Juego de La Pirámide</title>
    <link rel="stylesheet" href="/css/toastify.min.css">
    <link rel="stylesheet" href="/css/pyramid.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&family=Montserrat:wght@700&display=swap" rel="stylesheet">
    <meta name="google-adsense-account" content="ca-pub-8003242291729928">
    <script async src="https.pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8003242291729928"
     crossorigin="anonymous"></script>
</head>
<body class="bg-dark text-light">
    <%- include('partials/header') %>

    <header class="game-header">
        <div class="game-card" id="player-list-card">
            <h2>Jugadores</h2>
            <ul id="player-list"></ul>
        </div>
        <div class="game-card" id="actions-log-area">
            <h2>Acciones</h2>
            <div id="actions-log"></div>
        </div>
    </header>

    <main class="game-main-area">
        <div id="pyramid-area">
            <!-- Las cartas de la pirámide se generarán aquí -->
        </div>
    </main>

    <footer class="player-footer">
        <h2>Tus Cartas</h2>
        <div id="player-hand"></div>
        <div id="player-actions">
            <!-- Buttons will be rendered here by JS -->
        </div>
        <div id="my-drinks-count"></div>
    </footer>

    <!-- Modals -->
    <div id="name-modal" class="modal-overlay">
        <div class="modal-content">
            <h2>Elige tu nombre</h2>
            <input type="text" id="name-input" placeholder="Tu nombre...">
            <button id="join-game-btn" class="btn-custom">Unirse al Juego</button>
        </div>
    </div>

    <div id="target-modal" class="modal-overlay" style="display: none;">
        <div class="modal-content">
            <h2>¿A quién mandas beber?</h2>
            <div id="target-player-list"></div>
            <button id="cancel-target-btn" class="btn-custom">Cancelar</button>
        </div>
    </div>

    <div id="challenge-modal" class="modal-overlay" style="display: none;">
        <div class="modal-content">
            <h2 id="challenge-title">¡Te han mandado a beber!</h2>
            <p id="challenge-text"></p>
            <div id="challenge-pyramid-card"></div>
            <div class="challenge-actions">
                <button id="challenge-accept-btn" class="btn-custom">Beber</button>
                <button id="challenge-reject-btn" class="btn-custom">Desafiar</button>
            </div>
        </div>
    </div>

    <%- include('partials/game_rules', { gameType: 'pyramid' }) %>

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/toastify.min.js"></script>
    <script src="/js/pyramid.js"></script>
</body>
</html>
